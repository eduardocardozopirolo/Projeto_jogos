{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run projeto_jogos-3",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        ":lwjgl3:run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Build projeto_jogos-3",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "clean",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [
        "$javac"
      ]
    }
  ]
}
